{
  "name": "kiln-agentd",
  "private": true,
  "version": "0.1.0",
  "description": "Kiln agent runner: thin control plane between the Kiln PWA and per-session sandbox microVMs",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/src/index.js",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "fastify": "^5.10.0",
    "undici": "^8.7.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "typescript": "^7.0.2"
  },
  "license": "Apache-2.0"
}
